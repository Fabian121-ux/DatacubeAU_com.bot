APP_NAME=Datacube AU WhatsApp Bot
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
ADMIN_API_TOKEN=local-admin-token
STARTUP_VALIDATE_DB=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datacube_bot
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

WAHA_SERVICE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION_NAME=default
WAHA_SEND_PATH=/api/sendText
WAHA_SESSION_STATUS_PATH=/api/sessions
WAHA_REQUEST_TIMEOUT_SECONDS=15

BOT_WA_NUMBER=234000000001@c.us
BOT_MENTION_ALIASES=datacube bot,datacubeau
ENABLE_AUTO_REPLY=true
GROUP_DEFAULT_REPLY_MODE=mention_only
GROUP_DEFAULT_COOLDOWN_SECONDS=45
DM_DEFAULT_COOLDOWN_SECONDS=6
KB_MAX_CHUNKS=3
KB_MIN_SCORE=0.34
KB_REPLY_MAX_CHARS=420
RECENT_ITEMS_LIMIT=50

AI_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_LIGHT=openai/gpt-4o-mini
OPENROUTER_MODEL_DEEP=openai/gpt-4o
OPENROUTER_TIMEOUT_SECONDS=25
OPENROUTER_RETRY_COUNT=2

LOCAL_TEST_DM_WHATSAPP_ID=234000000000@c.us
LOCAL_TEST_GROUP_CHAT_ID=120363000000000000@g.us
