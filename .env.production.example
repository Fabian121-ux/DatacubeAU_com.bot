# WAHA container settings
WAHA_IMAGE=devlikeapro/waha:latest
WAHA_HTTP_PORT=3000
WAHA_CONTAINER_DATA_PATH=/app/.sessions
WAHA_BASE_URL=http://YOUR_DROPLET_IP:3000
